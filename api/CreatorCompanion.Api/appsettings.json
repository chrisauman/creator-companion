{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "CreatorCompanion",
    "Audience": "CreatorCompanionUsers",
    "ExpiryMinutes": 60,
    "RefreshExpiryDays": 30
  },
  "RateLimit": {
    "AuthWindowSeconds": 60,
    "AuthMaxRequests": 10,
    "WriteWindowSeconds": 60,
    "WriteMaxRequests": 30
  },
  "Vapid": {
    "Subject": "",
    "PublicKey": "",
    "PrivateKey": ""
  },
  "EntryLimits": {
    "Free": {
      "MaxWordsPerEntry": 100,
      "MaxImagesPerEntry": 1,
      "MaxRemindersPerDay": 1,
      "CanUsePause": false,
      "CanBackfill": false,
      "CanRecoverDeleted": false,
      "CanTrackMood": false,
      "CanFavorite": false,
      "CanFormatText": false,
      "MaxEntriesPerDay": 1,
      "MaxTagsPerEntry": 3,
      "MaxDiaries": 1
    },
    "Paid": {
      "MaxWordsPerEntry": 2500,
      "MaxImagesPerEntry": 20,
      "MaxRemindersPerDay": 5,
      "CanUsePause": true,
      "CanBackfill": true,
      "CanRecoverDeleted": true,
      "CanTrackMood": true,
      "CanFavorite": true,
      "CanFormatText": true,
      "MaxEntriesPerDay": 5,
      "MaxTagsPerEntry": 20,
      "MaxDiaries": -1
    }
  }
}
