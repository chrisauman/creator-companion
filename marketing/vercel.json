{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/morning-pages-app.html",
      "destination": "/morning-pages-app",
      "permanent": true
    },
    {
      "source": "/preview.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/faq.html",
      "destination": "/#faq-home",
      "permanent": true
    },
    {
      "source": "/faq",
      "destination": "/#faq-home",
      "permanent": true
    },
    {
      "source": "/pricing.html",
      "destination": "/#pricing",
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/#pricing",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://creator-companion-api-production.up.railway.app/v1/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://creator-companion-api-production.up.railway.app/v1/lp/sitemap.xml"
    },
    {
      "source": "/resources",
      "destination": "https://creator-companion-api-production.up.railway.app/v1/lp/hub"
    },
    {
      "source": "/lp-img/:id",
      "destination": "https://creator-companion-api-production.up.railway.app/v1/public/social-card/:id.png"
    },
    {
      "source": "/:slug",
      "destination": "https://creator-companion-api-production.up.railway.app/v1/lp/:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.creatorcompanionapp.com https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https://app.creatorcompanionapp.com https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
